{
  "manifest_version": 3,
  "name": "Auto Tool Shopee Extractor",
  "version": "0.1.0",
  "description": "Extract visible Shopee product information and send it to Auto Tool.",
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Auto Tool"
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://shopee.vn/*",
    "https://*.shopee.vn/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "src/background/serviceWorker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://shopee.vn/*",
        "https://*.shopee.vn/*"
      ],
      "js": [
        "src/content/shopeeContentScript.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
